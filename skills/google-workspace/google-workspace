#!/bin/bash
# Google Workspace OpenClaw Skill - Using gws-auth CLI

ACTION="$1"
shift

case "$ACTION" in
    calendar-list)
        MAX="${1:-10}"
        gws-auth calendar events list --params "{\"calendarId\":\"primary\",\"maxResults\":$MAX,\"singleEvents\":true,\"orderBy\":\"startTime\",\"timeMin\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}" 2>&1
        ;;

    calendar-create)
        TITLE="$1"
        START="$2"
        END="$3"
        ATTENDEES="$4"
        if [ -n "$ATTENDEES" ]; then
            gws-auth calendar +insert --summary "$TITLE" --start "$START" --end "$END" --attendee "$ATTENDEES" 2>&1
        else
            gws-auth calendar +insert --summary "$TITLE" --start "$START" --end "$END" 2>&1
        fi
        ;;

    calendar-delete)
        EVENT_ID="$1"
        gws-auth calendar events delete --params "{\"calendarId\":\"primary\",\"eventId\":\"$EVENT_ID\"}" 2>&1
        ;;

    gmail-send)
        TO="$1"
        SUBJECT="$2"
        BODY="$3"
        gws-auth gmail +send --to "$TO" --subject "$SUBJECT" --body "$BODY" 2>&1
        ;;

    gmail-read)
        QUERY="${1:-is:unread}"
        MAX="${2:-10}"
        gws-auth gmail users threads list --params "{\"userId\":\"me\",\"q\":\"$QUERY\",\"maxResults\":$MAX}" 2>&1
        ;;

    calendar-availability)
        echo "Checking availability using calendar list..."
        gws-auth calendar +agenda --week 2>&1
        ;;

    *)
        echo "Unknown action: $ACTION"
        echo "Available: calendar-list, calendar-create, calendar-delete, gmail-send, gmail-read, calendar-availability"
        exit 1
        ;;
esac
